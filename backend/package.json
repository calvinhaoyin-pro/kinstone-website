{
  "name": "kinstone-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Minimal Inquiry Service API for the Kinstone website (see docs/design/01-backend-architecture.md).",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/lambda.cjs",
    "package:lambda": "npm run build:lambda && cd dist && rm -f ../function.zip && zip -r ../function.zip lambda.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1077.0",
    "@codegenie/serverless-express": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  }
}
