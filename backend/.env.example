# Copy to .env and adjust as needed for local development.

PORT=4000
CORS_ORIGIN=http://localhost:5173

# Sender/recipient for inquiry notification emails. In Lambda, SES_FROM_EMAIL
# must be a verified SES identity (see docs/design/04-infra-design.md).
SES_FROM_EMAIL=no-reply@kinstone.example
SES_TO_EMAIL=sales@kinstone.example
AWS_REGION=us-east-1

# Optional override for backend/src/services/mailer.ts. Defaults to "ses"
# when running in Lambda (AWS sets AWS_LAMBDA_FUNCTION_NAME automatically)
# and "console" otherwise, so local dev never needs real AWS credentials.
# MAILER_DRIVER=console

# [TODO] Optional inquiry log table — only used by the in-memory store stub
# locally. Not required for v1 (email is the source of truth); wire up to
# real DynamoDB only if you want a durable/searchable inquiry log.
DYNAMODB_TABLE=kinstone-inquiries-dev
